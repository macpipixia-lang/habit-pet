generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  username     String      @unique
  passwordHash String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  profile      Profile?
  dailyLogs    DailyLog[]
  pointsLedger PointsLedger[]
}

model Profile {
  id                String   @id @default(cuid())
  userId            String   @unique
  displayName       String?
  exp               Int      @default(0)
  level             Int      @default(1)
  points            Int      @default(0)
  streak            Int      @default(0)
  makeupCards       Int      @default(0)
  purchaseCount     Int      @default(0)
  lastSettledDate   String?
  lastCompletedDate String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyLog {
  id            String   @id @default(cuid())
  userId        String
  date          String
  tasksJson     String
  completedTaskIds String @default("[]")
  settledAt     DateTime?
  earnedExp     Int      @default(0)
  earnedPoints  Int      @default(0)
  streakAfter   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model PointsLedger {
  id          String   @id @default(cuid())
  userId      String
  delta       Int
  reason      String
  description String
  metaJson    String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
