generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  username     String      @unique
  passwordHash String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  profile      Profile?
  dailyLogs    DailyLog[]
  pointsLedger PointsLedger[]
  purchases    UserPurchase[]
  redeemCodes  RedeemCode[]
}

model Profile {
  id                String   @id @default(cuid())
  userId            String   @unique
  displayName       String?
  exp               Int      @default(0)
  level             Int      @default(1)
  points            Int      @default(0)
  streak            Int      @default(0)
  makeupCards       Int      @default(0)
  purchaseCount     Int      @default(0)
  lastSettledDate   String?
  lastCompletedDate String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyLog {
  id            String   @id @default(cuid())
  userId        String
  date          String
  tasksJson     String
  completedTaskIds String @default("[]")
  settledAt     DateTime?
  earnedExp     Int      @default(0)
  earnedPoints  Int      @default(0)
  streakAfter   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model PointsLedger {
  id          String   @id @default(cuid())
  userId      String
  delta       Int
  reason      String
  description String
  metaJson    String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ShopItem {
  id            String         @id @default(cuid())
  slug          String         @unique
  nameZh        String
  descriptionZh String
  kind          ShopItemKind
  priceBase     Int
  priceStep     Int
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  purchases     UserPurchase[]
  redeemCodes   RedeemCode[]
}

model UserPurchase {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  quantity  Int
  totalCost Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item      ShopItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([userId, itemId])
}

model RedeemCode {
  id         String           @id @default(uuid())
  userId     String
  itemId     String
  status     RedeemCodeStatus @default(ISSUED)
  issuedAt   DateTime         @default(now())
  redeemedAt DateTime?
  adminNote  String?
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  item       ShopItem         @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([status, issuedAt])
  @@index([userId, issuedAt])
}

enum ShopItemKind {
  MAKEUP_CARD
  COUPON
}

enum RedeemCodeStatus {
  ISSUED
  REDEEMED
  VOID
}
